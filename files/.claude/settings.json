{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(aws sts get-cellar-identity:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(go build:*)",
      "Bash(go get:*)",
      "Bash(go install:*)",
      "Bash(go list:*)",
      "Bash(go mod tidy)",
      "Bash(go vet:*)",
      "Bash(ls:*)"
    ],
    "ask": [
      "Bash(git rm:*)",
      "Bash(git push:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/local/bin/claude-notify-approval.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/local/bin/claude-notify-stop.sh",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "cc-skills-golang@samber": true
  },
  "extraKnownMarketplaces": {
    "samber": {
      "source": {
        "source": "github",
        "repo": "samber/cc"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "~/local/bin/claude-statusline.sh"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "アメリアがコーヒードリップ中……",
      "アリス、占い中……",
      "エーリアスへ移動中……",
      "エシュールがパン焼き中……",
      "エルフィン、マシュマロ横領中……",
      "エルフィンがデザートを味わい中……",
      "カンナ、今日も夜間の当番中……",
      "ギデオン、夜空を見ている……",
      "コミーが睡眠中……",
      "シーラ、風にあたっている……",
      "シェイディ、偉大な悪戯を計画中……",
      "ジュビーが蜂蜜を運搬中……",
      "ディアナが目覚め中……",
      "ネル、お祈り中……",
      "バター、蝶を追跡中……",
      "ビッグウッド、実を育てている……",
      "フリックル、ベリータが隠したチョコレートを探している……",
      "マエストロがチャージ中……",
      "メロナ、水やり中……",
      "メロンマスクが水やり中……",
      "ルード、スクワット中……",
      "復活エネルギー収集中"
    ]
  }
}
